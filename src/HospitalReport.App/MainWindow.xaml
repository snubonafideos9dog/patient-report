<Window x:Class="HospitalReport.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환자 경과 레포트 생성기"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="10" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="환자번호"/>
                <TextBox Grid.Column="1" Margin="6,0" Text="{Binding PatientIdInput, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="환자명(보조)"/>
                <TextBox Grid.Column="3" Margin="6,0" Text="{Binding PatientNameInput, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Grid.Column="4" Margin="10,0,0,0" Height="30" Content="조회" Command="{Binding SearchCommand}"/>
                <Button Grid.Column="5" Margin="10,0,0,0" Height="30" Content="레포트 생성" Command="{Binding GenerateReportCommand}"/>
                <Button Grid.Column="6" Margin="10,0,0,0" Height="30" Content="PACS 진단" Command="{Binding RunPacsDiagnosticCommand}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="220"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Header="환자 기본정보" Padding="8">
                    <StackPanel>
                        <TextBlock Text="{Binding Patient.PatientId, StringFormat=환자번호: {0}}" Margin="0,2"/>
                        <TextBlock Text="{Binding Patient.PatientName, StringFormat=환자명: {0}}" Margin="0,2"/>
                        <TextBlock Text="{Binding Patient.Age, StringFormat=나이: {0}}" Margin="0,2"/>
                        <TextBlock Text="{Binding Patient.Sex, StringFormat=성별: {0}}" Margin="0,2"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="X-ray Preview" Margin="0,10,0,0" Padding="8">
                    <Border Background="#111">
                        <Image Source="{Binding PreviewImagePath}" Stretch="Uniform"/>
                    </Border>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="X-ray 메타데이터" Margin="0,10,0,0" Padding="8">
                    <StackPanel>
                        <TextBlock Text="{Binding LatestXray.StudyDate, StringFormat=촬영일: {0:yyyy-MM-dd}}" Margin="0,2"/>
                        <TextBlock Text="{Binding LatestXray.Modality, StringFormat=Modality: {0}}" Margin="0,2"/>
                        <TextBlock Text="{Binding LatestXray.StudyDescription, StringFormat=Study: {0}}" Margin="0,2"/>
                        <TextBlock Text="{Binding LatestXray.SeriesDescription, StringFormat=Series: {0}}" TextWrapping="Wrap" Margin="0,2"/>
                        <TextBlock Text="{Binding LatestXray.FilePath, StringFormat=파일: {0}}" TextWrapping="Wrap" Margin="0,2"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="3" Header="최신 차트 원문" Margin="0,10,0,0" Padding="8">
                    <TextBox Text="{Binding LatestChart.RawText}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                </GroupBox>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="140"/>
                </Grid.RowDefinitions>

                <GroupBox Header="레포트 초안" Padding="8">
                    <StackPanel>
                        <TextBox FontSize="18" FontWeight="Bold" Text="{Binding Report.SummaryTitle}" Margin="0,0,0,8"/>
                        <TextBlock Text="요약" FontWeight="Bold"/>
                        <TextBox Text="{Binding Report.SummaryText}" AcceptsReturn="True" TextWrapping="Wrap" Height="80"/>

                        <TextBlock Margin="0,12,0,0" Text="X-ray 설명" FontWeight="Bold"/>
                        <TextBox Text="{Binding Report.XrayFindingsPatientFriendly}" AcceptsReturn="True" TextWrapping="Wrap" Height="80"/>

                        <TextBlock Margin="0,12,0,0" Text="치료 경과" FontWeight="Bold"/>
                        <TextBox Text="{Binding Report.TreatmentProgress}" AcceptsReturn="True" TextWrapping="Wrap" Height="80"/>

                        <TextBlock Margin="0,12,0,0" Text="재진 안내" FontWeight="Bold"/>
                        <TextBox Text="{Binding Report.NextVisitReason}" AcceptsReturn="True" TextWrapping="Wrap" Height="80"/>

                        <TextBlock Margin="0,12,0,0" Text="주의사항" FontWeight="Bold"/>
                        <TextBox Text="{Binding Report.Caution}" AcceptsReturn="True" TextWrapping="Wrap" Height="80"/>
                    </StackPanel>
                </GroupBox>

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="카카오/문자용 짧은 문구" Margin="0,0,6,0" Padding="8">
                        <TextBox Text="{Binding Report.ShortKakaoMessage}" AcceptsReturn="True" TextWrapping="Wrap"/>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="PACS 진단 결과" Margin="6,0,0,0" Padding="8">
                        <TextBox Text="{Binding DiagnosticText}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
                    </GroupBox>
                </Grid>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
