<Window x:Class="HospitalReport.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="환자 경과 레포트 생성기"
        Height="940" Width="1580"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 입력바 -->
        <Border Grid.Row="0" Padding="10" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="환자번호(차트번호)" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Width="200" Height="30" Margin="10,0" VerticalContentAlignment="Center"
                         Text="{Binding PatientIdInput, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Width="90" Height="30" Margin="0,0,8,0" Content="조회" Command="{Binding SearchCommand}"/>
                <Button Width="90" Height="30" Margin="0,0,8,0" Content="초기화" Command="{Binding ClearCommand}"/>
                <Button Width="90" Height="30" Content="PACS 진단" Command="{Binding RunPacsDiagnosticCommand}"/>
                <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" Foreground="#888"
                           Text="※ EMR 미연동 — PACS 영상 기반 · Claude 판독은 참고용 초안(의사 검토 필요)"/>
            </StackPanel>
        </Border>

        <!-- 본문 3열 -->
        <Grid Grid.Row="1" Margin="0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Col 1: 촬영 리스트(아코디언) + 환자정보 + 전/후 지정 -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <GroupBox Header="촬영 목록 (종류별)" Padding="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Margin="0,2">
                                        <Expander.Header>
                                            <TextBlock Text="{Binding Header}" FontWeight="Bold" Foreground="#0066CC"/>
                                        </Expander.Header>
                                        <ItemsControl ItemsSource="{Binding Items}" Margin="4,4,0,4">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="4" Margin="0,1" Padding="6,4" Cursor="Hand">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#D6E9FF"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.SelectItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding StudyDescription}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                            <TextBlock FontSize="11" Foreground="#666">
                                                                <Run Text="{Binding DateText, Mode=OneWay}"/><Run Text=" · "/><Run Text="{Binding ImageCount, Mode=OneWay}"/><Run Text="장 · "/><Run Text="{Binding Modality, Mode=OneWay}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="환자 기본정보" Margin="0,10,0,0" Padding="8">
                    <StackPanel>
                        <TextBlock Text="{Binding Patient.PatientId, StringFormat=환자번호: {0}}" Margin="0,1"/>
                        <TextBlock Text="{Binding Patient.PatientName, StringFormat=환자명: {0}}" Margin="0,1"/>
                        <TextBlock Text="{Binding Patient.Age, StringFormat=나이: {0}}" Margin="0,1"/>
                        <TextBlock Text="{Binding Patient.Sex, StringFormat=성별: {0}}" Margin="0,1"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="2" Header="치료 전/후 지정" Margin="0,10,0,0" Padding="8">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Margin="0,0,4,0" Height="28" Content="◀ 치료 전 지정" Command="{Binding SetBeforeCommand}"/>
                            <Button Grid.Column="1" Margin="4,0,0,0" Height="28" Content="치료 후 지정 ▶" Command="{Binding SetAfterCommand}"/>
                        </Grid>
                        <TextBlock Margin="0,8,0,0" FontSize="12">
                            <Run Text="치료 전: " FontWeight="Bold" Foreground="#546e7a"/>
                            <Run Text="{Binding BeforeLabel, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Margin="0,3,0,0" FontSize="12">
                            <Run Text="치료 후: " FontWeight="Bold" Foreground="#2e7d32"/>
                            <Run Text="{Binding AfterLabel, Mode=OneWay}"/>
                        </TextBlock>
                        <Button Margin="0,10,0,0" Height="36" Content="레포트 생성 (Claude 판독)" FontWeight="Bold"
                                Command="{Binding GenerateComparisonCommand}"/>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <!-- Col 2: Preview(다중 이미지) + 메타데이터 -->
            <Grid Grid.Column="1" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <GroupBox Header="Preview (선택 항목)" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                            <Button Content="◀" Width="34" Height="26" Command="{Binding PrevImageCommand}"/>
                            <TextBlock Text="{Binding PreviewIndexText}" VerticalAlignment="Center" Margin="10,0" MinWidth="64" TextAlignment="Center"/>
                            <Button Content="▶" Width="34" Height="26" Command="{Binding NextImageCommand}"/>
                            <Button Content="🔍 확대" Width="80" Height="26" Margin="18,0,0,0" Command="{Binding OpenViewerCommand}"/>
                        </StackPanel>
                        <Border Grid.Row="1" Background="#111">
                            <Image Source="{Binding PreviewImage}" Stretch="Uniform"/>
                        </Border>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="1" Header="메타데이터" Margin="0,10,0,0" Padding="8">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedStudy.DateText, StringFormat=촬영일: {0}}" Margin="0,1"/>
                        <TextBlock Text="{Binding SelectedStudy.ModalityGroup, StringFormat=종류: {0}}" Margin="0,1"/>
                        <TextBlock Text="{Binding SelectedStudy.Modality, StringFormat=Modality: {0}}" Margin="0,1"/>
                        <TextBlock Text="{Binding SelectedStudy.StudyDescription, StringFormat=검사명: {0}}" TextWrapping="Wrap" Margin="0,1"/>
                        <TextBlock Text="{Binding SelectedStudy.ImageCount, StringFormat=영상 수: {0}장}" Margin="0,1"/>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <!-- Col 3: 레포트(WebView2) + PDF -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="판독 레포트" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                    <Button x:Name="SavePdfButton" Margin="16,0,0,0" Width="140" Height="30"
                            Content="PDF 저장" Click="SavePdfButton_Click"
                            IsEnabled="{Binding HasReport}"/>
                </StackPanel>

                <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
                    <wv2:WebView2 x:Name="ReportView"/>
                </Border>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
