<Window x:Class="HospitalReport.App.JsPacsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="JS PACS · 판독/계측"
        Height="980" Width="1600"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <wv2:WebView2 x:Name="Web"/>
        <Border x:Name="StatusOverlay" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,8,0,0" Padding="12,6" Background="#CC1F2937" CornerRadius="8"
                Visibility="Collapsed">
            <TextBlock x:Name="StatusText" Foreground="#E8EEF6" FontSize="12"/>
        </Border>
    </Grid>
</Window>
