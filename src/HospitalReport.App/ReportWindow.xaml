<Window x:Class="HospitalReport.App.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Claude 판독 레포트"
        Height="1000" Width="1100"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,8">
            <TextBlock Text="판독 레포트" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
            <Button x:Name="SavePdfButton" Margin="16,0,0,0" Width="140" Height="30"
                    Content="📄 PDF 저장" Click="SavePdfButton_Click"/>
            <TextBlock x:Name="StatusText" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#666"/>
        </StackPanel>

        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" Margin="6,0,6,6">
            <wv2:WebView2 x:Name="ReportView"/>
        </Border>
    </Grid>
</Window>
