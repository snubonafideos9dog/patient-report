<Window x:Class="HospitalReport.App.ImageViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="영상 뷰어"
        Height="800" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1b1b1b">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 툴바 -->
        <Border Grid.Row="0" Background="#2b2b2b" Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="PrevBtn" Width="70" Height="30" Content="◀ 이전" Click="Prev_Click"/>
                <TextBlock x:Name="IndexText" Foreground="White" VerticalAlignment="Center" Margin="12,0" MinWidth="70" TextAlignment="Center"/>
                <Button x:Name="NextBtn" Width="70" Height="30" Content="다음 ▶" Click="Next_Click"/>
                <Rectangle Width="1" Fill="#555" Margin="16,2"/>
                <Button Width="40" Height="30" Content="－" FontSize="16" Click="ZoomOut_Click"/>
                <TextBlock x:Name="ZoomText" Foreground="White" VerticalAlignment="Center" Margin="10,0" MinWidth="52" TextAlignment="Center"/>
                <Button Width="40" Height="30" Content="＋" FontSize="16" Click="ZoomIn_Click"/>
                <Button Width="80" Height="30" Margin="10,0,0,0" Content="맞춤(100%)" Click="ZoomReset_Click"/>
            </StackPanel>
        </Border>

        <!-- 이미지 영역 (반응형: 창 크기에 맞춰 Uniform, 위에 줌/팬) -->
        <ScrollViewer x:Name="Scroll" Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="#111"
                      PreviewMouseWheel="Scroll_PreviewMouseWheel"
                      PreviewMouseLeftButtonDown="Scroll_MouseLeftDown"
                      PreviewMouseMove="Scroll_MouseMove"
                      PreviewMouseLeftButtonUp="Scroll_MouseLeftUp">
            <Image x:Name="Img" Stretch="Uniform">
                <Image.LayoutTransform>
                    <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1"/>
                </Image.LayoutTransform>
            </Image>
        </ScrollViewer>

        <StatusBar Grid.Row="2" Background="#2b2b2b">
            <StatusBarItem>
                <TextBlock x:Name="InfoText" Foreground="#bbb"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
